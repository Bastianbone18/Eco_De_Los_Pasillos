[sub_resource type="GDScript" id="GDScript_tgpf3"]
script/source = "extends StaticBody3D

var isVist = false
var canInteract = true

# Llamado cuando el nodo entra por primera vez al árbol de escena.
func _ready():
	$AnimationPlayer.animation_finished.connect(self._on_animation_player_animation_finished)

# Acción de uso, por ejemplo, cuando se presiona la tecla \"E\".
func action_use():
	if canInteract:
		if not isVist:
			visi_ble()
		else:
			baja_da()

# Función para reproducir la animación \"Revisar\".
func visi_ble():
	canInteract = false
	$AnimationPlayer.play(\"Revisar\")
	isVist = true

# Función para reproducir la animación \"Bajar\".
func baja_da():
	canInteract = false
	$AnimationPlayer.play(\"Bajar\")
	isVist = false

# Callback cuando termina una animación.
func _on_animation_player_animation_finished(anim_name: String) -> void:
	canInteract = true
"

