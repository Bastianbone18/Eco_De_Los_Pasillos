; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Echoes of the Forgotten"
run/main_scene="res://Pantallas/menu.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
boot_splash/bg_color=Color(0.0431373, 0, 0.0117647, 1)
boot_splash/image="res://Simbologia.png"
config/icon="res://Echoes of the ForgottenFinal.png"
boot_splash/minimum_display_time=2500

[autoload]

GameData="*res://Datos_guardados/game_data.gd"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"
InputGate="*res://input_gate.gd"
DisplaySettings="*res://Datos_guardados/DisplaySettings.gd"
SaveManager="*res://Datos_guardados/SaveManager.gd"
SaveIndicator="*res://Pantallas/SaveIndicator.tscn"
MusicManager="*res://Datos_guardados/music_manager.tscn"

[dialogue_manager]

general/balloon_path="res://Pantallas/Dialogos_ecenas/balloon.tscn"

[display]

window/size/viewport_width=320
window/size/viewport_height=240
window/size/borderless=true
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"
window/stretch/aspect="expand"
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg")

[filesystem]

import/fbx/enabled=false

[global_group]

title=""
botones=""

