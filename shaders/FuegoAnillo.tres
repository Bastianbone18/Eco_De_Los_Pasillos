[resource]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx, depth_prepass_alpha;

uniform vec2 displaceSpeed;
uniform vec2 DisplacementScale2 = vec2(1.000000, 1.000000);
uniform sampler2D Desplazamiento : hint_default_black, filter_nearest_mipmap;
uniform float IntensidadDespla = 0.20000000298023;
uniform vec2 Speed;
uniform vec2 Scale = vec2(1.000000, 1.000000);
uniform sampler2D Texture2DParameter : filter_nearest_mipmap;
uniform sampler2D Textureadd : hint_default_black, filter_nearest_mipmap, repeat_disable;
uniform sampler2D Texturedsubtracion : hint_default_black, filter_nearest_mipmap, repeat_disable;
uniform sampler2D Paletadecolor : hint_default_black, filter_nearest_mipmap, repeat_disable;



void vertex() {
// Input:2
	vec3 n_out2p0 = VERTEX;


// Vector2Parameter:6
	vec2 n_out6p0 = displaceSpeed;


// Input:7
	float n_out7p0 = TIME;


// VectorOp:8
	vec2 n_out8p0 = n_out6p0 * vec2(n_out7p0);


// UVFunc:5
	vec2 n_in5p1 = vec2(1.00000, 1.00000);
	vec2 n_out5p0 = n_out8p0 * n_in5p1 + UV;


// Vector2Parameter:10
	vec2 n_out10p0 = DisplacementScale2;


// UVFunc:9
	vec2 n_in9p2 = vec2(0.00000, 0.00000);
	vec2 n_out9p0 = (n_out5p0 - n_in9p2) * n_out10p0 + n_in9p2;


	vec4 n_out11p0;
// Texture2D:11
	n_out11p0 = texture(Desplazamiento, n_out9p0);
	float n_out11p1 = n_out11p0.r;


// FloatParameter:15
	float n_out15p0 = IntensidadDespla;


// FloatOp:14
	float n_out14p0 = n_out11p1 * n_out15p0;


// Input:12
	vec3 n_out12p0 = NORMAL;


// VectorOp:13
	vec2 n_out13p0 = vec2(n_out14p0) * vec2(n_out12p0.xy);


// VectorOp:3
	vec3 n_out3p0 = n_out2p0 + vec3(n_out13p0, 0.0);


// Output:0
	VERTEX = n_out3p0;


}

void fragment() {
// Vector2Parameter:5
	vec2 n_out5p0 = Speed;


// Input:6
	float n_out6p0 = TIME;


// VectorOp:7
	vec2 n_out7p0 = n_out5p0 * vec2(n_out6p0);


// UVFunc:4
	vec2 n_in4p1 = vec2(1.00000, 1.00000);
	vec2 n_out4p0 = n_out7p0 * n_in4p1 + UV;


// Vector2Parameter:9
	vec2 n_out9p0 = Scale;


// UVFunc:8
	vec2 n_in8p2 = vec2(0.00000, 0.00000);
	vec2 n_out8p0 = (n_out4p0 - n_in8p2) * n_out9p0 + n_in8p2;


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(Texture2DParameter, n_out8p0);
	float n_out3p1 = n_out3p0.r;


	vec4 n_out10p0;
// Texture2D:10
	n_out10p0 = texture(Textureadd, UV);
	float n_out10p1 = n_out10p0.r;


// FloatOp:12
	float n_out12p0 = n_out3p1 + n_out10p1;


	vec4 n_out14p0;
// Texture2D:14
	n_out14p0 = texture(Texturedsubtracion, UV);
	float n_out14p1 = n_out14p0.r;


// FloatOp:15
	float n_out15p0 = n_out12p0 - n_out14p1;


// Clamp:16
	float n_in16p1 = 0.00000;
	float n_in16p2 = 1.00000;
	float n_out16p0 = clamp(n_out15p0, n_in16p1, n_in16p2);


	vec4 n_out17p0;
// Texture2D:17
	n_out17p0 = texture(Paletadecolor, vec2(n_out16p0));
	float n_out17p4 = n_out17p0.a;


// Output:0
	ALBEDO = vec3(n_out17p0.xyz);
	ALPHA = n_out17p4;
	EMISSION = vec3(n_out17p0.xyz);


}
"
